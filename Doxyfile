# Doxyfile for KanoopCommonQt
# Run: doxygen Doxyfile  (from the KanoopCommonQt directory)
# Output: docs/html/index.html

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = KanoopCommonQt
PROJECT_NUMBER         = 2.1.1
PROJECT_BRIEF          = "Kanoop foundational Qt utility library"
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include/
RECURSIVE              = YES
FILE_PATTERNS          = *.h
EXCLUDE_PATTERNS       = */moc_* */ui_*

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Build settings
#---------------------------------------------------------------------------
JAVADOC_AUTOBRIEF      = YES
TAB_SIZE               = 4
BUILTIN_STL_SUPPORT    = YES
CLANG_ASSISTED_PARSING = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
